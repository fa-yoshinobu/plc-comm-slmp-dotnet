{
  "metadata": [
    {
      "src": [
        {
          "files": ["src/**/*.csproj"]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["docs/**/*.md", "api/*.yml"]
      },
      {
        "files": ["README.md", "CHANGELOG.md", "TODO.md"]
      }
    ],
    "resource": [
      {
        "files": ["LICENSE"]
      }
    ],
    "dest": "publish/docs",
    "template": ["default", "modern"]
  }
}
